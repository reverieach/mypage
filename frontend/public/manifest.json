{
  "manifest_version": 3,
  "name": "MyPage",
  "description": "Personal start page for Chrome and Edge.",
  "version": "0.1.0",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "deepseek-fill.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:3217/*",
    "https://chat.deepseek.com/*"
  ],
  "permissions": [
    "clipboardWrite"
  ]
}
